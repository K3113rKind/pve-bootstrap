#!/bin/bash
# =============================================================================
# config.local.sh.example
#
# Kopiere zu config.local.sh und passe an deine Umgebung an:
#   cp config.local.sh.example config.local.sh
#   nano config.local.sh
#
# config.local.sh ist via .gitignore vom Repo ausgeschlossen.
# =============================================================================

# --- NFS-Storage einbinden ----------------------------------------------------
# NFS_SERVER="192.168.0.4"
# NFS_STORAGES=(
#   "SynologyTemplate|/volume1/ProxmoxTemplates|iso,vztmpl"
#   "SynologyBackup|/volume1/ProxmoxBackup|backup"
# )

# --- Schedule überschreiben (optional) ----------------------------------------
# CRON_SCHEDULE="0 4 * * 0"   # Sonntag 04:00

# --- Feature-Toggles überschreiben (optional) ---------------------------------
# ENABLE_NAG_REMOVAL=false
# ENABLE_FAIL2BAN_PROXMOX_JAIL=false

# --- Zusätzliche Host-Tools (optional) ----------------------------------------
# HOST_TOOLS="$HOST_TOOLS tmux ripgrep fzf"
